# Living Paris API — production (Cloudflare Workers)
API_URL=https://living-paris-api.living-paris.workers.dev
NEXT_PUBLIC_API_URL=https://living-paris-api.living-paris.workers.dev

# Public site URL (OpenRouter HTTP-Referer). On Vercel, VERCEL_URL is used automatically if unset.
# NEXT_PUBLIC_APP_URL=https://living-paris.vercel.app

# Local dev — uncomment to run the API worker on your machine instead:
# API_URL=http://localhost:8787
# NEXT_PUBLIC_API_URL=http://localhost:8787

# Optional — set on Cloudflare Worker via: wrangler secret put MAPBOX_ACCESS_TOKEN
# Enables turn-by-turn walking routes; without it POST /api/routes uses a Turf estimate
MAPBOX_ACCESS_TOKEN=
# Client-side Mapbox GL basemap (public pk.* token) — required for map rendering
NEXT_PUBLIC_MAPBOX_TOKEN=
# Alias used by Living Paris Companion (Vite) — Next.js reads this as a fallback
VITE_MAPBOX_TOKEN=

# Cloudflare Worker CORS (set in wrangler.toml [vars] or dashboard)
# ALLOWED_ORIGIN=http://localhost:3000

# Optional — freeze map + intent state in localStorage for fast UI iteration (no tile reload)
NEXT_PUBLIC_UI_DEV_CACHE=false

# AI & Voice (Ali) — OpenRouter → Grok for POST /api/chat
# Copy to .env.local (dev) or Vercel Project → Settings → Environment Variables (prod)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=x-ai/grok-4.3
OPENROUTER_TTS_MODEL=x-ai/grok-voice-tts-1.0
OPENROUTER_TTS_VOICE=Ara

# Optional — live Paris AQI from https://aqicn.org/api/ (token: aqicn.org/data-platform/token)
WAQI_API_KEY=
