# Living Paris API — production (Cloudflare Workers)
API_URL=https://living-paris-api.living-paris.workers.dev
NEXT_PUBLIC_API_URL=https://living-paris-api.living-paris.workers.dev

# Local dev — uncomment to run the API worker on your machine instead:
# API_URL=http://localhost:8787
# NEXT_PUBLIC_API_URL=http://localhost:8787

# Optional — set on Cloudflare Worker via: wrangler secret put MAPBOX_ACCESS_TOKEN
# Enables turn-by-turn walking routes; without it POST /api/routes uses a Turf estimate
MAPBOX_ACCESS_TOKEN=

# Cloudflare Worker CORS (set in wrangler.toml [vars] or dashboard)
# ALLOWED_ORIGIN=http://localhost:3000

# AI & Voice (Ali) — OpenRouter → Grok for POST /api/chat
# Copy to .env.local and add your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=x-ai/grok-4.3
